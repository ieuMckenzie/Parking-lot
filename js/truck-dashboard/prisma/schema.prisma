generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model TruckDetection {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  plateNumber String?
  usdotNumber String?
  unitId      String?
  cameraId    String?
}

model DockAssignment {
  id           Int    @id @default(autoincrement())
  plateNumber  String @unique
  assignedDock String
  status       String @default("scheduled")
}
