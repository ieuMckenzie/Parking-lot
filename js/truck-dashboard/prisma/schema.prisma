generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// logging truck detect
model TruckDetection {
  id           Int      @id @default(autoincrement())
  createdAt    DateTime @default(now())
  plateNumber  String?
  usdotNumber  String?
  unitId       String?
}

// assign dock
model DockAssignment {
  id           Int    @id @default(autoincrement())
  plateNumber  String @unique
  assignedDock String
  status       String @default("scheduled")
}